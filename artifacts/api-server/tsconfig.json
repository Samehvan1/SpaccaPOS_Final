{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@workspace/db": ["../../lib/db/src/index.ts"],
      "@workspace/api-zod": ["../../lib/api-zod/src/index.ts"]
    }
  },
  "include": ["src"]
}
